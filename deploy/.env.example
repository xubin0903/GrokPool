# GrokPool deploy/.env.example
# Copy:  cp .env.example .env
# NEVER commit .env

BIND_HOST=0.0.0.0
# Host port -> container 8080
SERVER_PORT=18080
SERVER_MODE=release
ENABLE_SERVER_TIMING=false
RUN_MODE=simple

POSTGRES_USER=sub2api
POSTGRES_PASSWORD=change-me-pg-password
POSTGRES_DB=sub2api
REDIS_PASSWORD=

ADMIN_EMAIL=admin@sub2api.local
ADMIN_PASSWORD=change-me-admin-password

# openssl rand -hex 32
JWT_SECRET=change-me-jwt-secret-32bytes-min
JWT_EXPIRE_HOUR=24
TOTP_ENCRYPTION_KEY=

TZ=Asia/Shanghai
LOG_LEVEL=info
LOG_FORMAT=json
LOG_SERVICE_NAME=sub2api
LOG_ENV=production
LOG_CALLER=true
LOG_STACKTRACE_LEVEL=error
LOG_OUTPUT_TO_STDOUT=true
LOG_OUTPUT_TO_FILE=true
LOG_ROTATION_MAX_SIZE_MB=100
LOG_ROTATION_MAX_BACKUPS=10
LOG_ROTATION_MAX_AGE_DAYS=7
LOG_ROTATION_COMPRESS=true
LOG_ROTATION_LOCAL_TIME=true

# Prefer Clash TUN / virtual NIC. Leave empty unless you know you need it.
UPDATE_PROXY_URL=
